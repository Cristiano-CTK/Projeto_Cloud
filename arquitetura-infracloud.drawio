        <mxCell id="govBox" value="GOVERNANÇA&#xa;• Management Groups + Subscriptions&#xa;• Azure Landing Zones&#xa;• Azure Policy (compliance/guardrails)&#xa;• RBAC + PIM (acesso mínimo / JIT)&#xa;• Padrão de Tags + Blueprints&#xa;• IaC: Terraform (pronto p/ multi-cloud)" style="rounded=6;whiteSpace=wrap;html=1;fillColor=#E3F0E3;strokeColor=#3C8C40;fontColor=#1B4D1F;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;fontStyle=0;" parent="1" vertex="1">
